.detail-page { height: 100vh; }

/* 比赛头部 */
.match-header {
  background: linear-gradient(135deg, #1a6b3a, #2d9e5f);
  padding: 30rpx 24rpx 40rpx;
  color: #fff;
}

.match-stage-time {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  opacity: 0.8;
  margin-bottom: 20rpx;
}

.teams-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.team-block {
  flex: 1;
  text-align: center;
}

.team-flag-big { font-size: 72rpx; }
.team-name-big { font-size: 26rpx; margin-top: 8rpx; font-weight: 600; }

.score-block { text-align: center; min-width: 140rpx; }
.vs-text { font-size: 40rpx; font-weight: 700; }
.live-score { font-size: 52rpx; font-weight: 700; }
.final-score { font-size: 52rpx; font-weight: 700; }
.live-badge { font-size: 22rpx; color: #ff6b6b; margin-top: 6rpx; }
.status-tag { display: inline-block; margin-top: 8rpx; }

/* 预测卡片 */
.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 24rpx;
}

.result-options {
  display: flex;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.result-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 10rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  background: #fafafa;
}

.result-btn.selected {
  border-color: #1a6b3a;
  background: #e6f4ec;
}

.result-btn-flag { font-size: 36rpx; }
.result-btn-label { font-size: 24rpx; color: #555; margin-top: 6rpx; }
.result-btn.selected .result-btn-label { color: #1a6b3a; font-weight: 600; }

/* 比分输入 */
.score-input-row { margin-bottom: 28rpx; }
.score-input-label { font-size: 24rpx; color: #888; display: block; margin-bottom: 14rpx; }
.score-inputs { gap: 16rpx; }
.score-input {
  width: 100rpx;
  height: 72rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  background: #fafafa;
}
.score-colon { font-size: 36rpx; font-weight: 700; color: #333; }

.submit-btn { width: 100%; }

.current-prediction-hint {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}

/* 已结束结果 */
.result-row { align-items: center; }
.predict-result-text { font-size: 30rpx; font-weight: 600; color: #222; }
.predict-score-text { font-size: 26rpx; color: #888; margin-top: 6rpx; }
.earned-score { font-size: 36rpx; font-weight: 700; }
.score-positive { color: #f5a623; }
.score-zero { color: #ccc; }

.locked-prediction { align-items: center; }
.no-prediction-text { color: #999; font-size: 26rpx; text-align: center; padding: 20rpx 0; }

/* 好友统计 */
.toggle-arrow { color: #ccc; }

.friend-stats {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.stat-col { flex: 1; text-align: center; }
.stat-col-label { font-size: 22rpx; color: #666; margin-bottom: 8rpx; }
.stat-col-bar {
  height: 8rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 6rpx;
}
.bar-fill { height: 100%; border-radius: 4rpx; }
.bar-fill.green { background: #1a6b3a; }
.bar-fill.gray { background: #bbb; }
.bar-fill.orange { background: #f5a623; }
.stat-col-pct { font-size: 24rpx; font-weight: 700; color: #333; margin-bottom: 10rpx; }
.avatar-group { display: flex; flex-wrap: wrap; justify-content: center; gap: 4rpx; }
.avatar-more { font-size: 20rpx; color: #999; align-self: center; }

/* 好友列表 */
.friend-row {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.friend-name { font-size: 26rpx; color: #333; margin-left: 12rpx; }
.friend-result { font-size: 24rpx; color: #666; }
.friend-score { font-size: 24rpx; color: #999; margin-left: 10rpx; }
.friend-correct { font-size: 28rpx; margin-left: 10rpx; font-weight: 700; }
.friend-correct.correct { color: #1a6b3a; }
.friend-correct.wrong { color: #ccc; }
.no-friends-text { color: #ccc; font-size: 26rpx; text-align: center; padding: 30rpx 0; }
