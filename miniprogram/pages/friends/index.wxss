.friends-page { display: flex; flex-direction: column; height: 100vh; background: #F5F6FA; }

/* 筛选 Tab */
.filter-bar {
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}
.filter-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 26rpx;
  color: #666;
  border-bottom: 4rpx solid transparent;
}
.filter-item.active { color: #1a6b3a; border-bottom-color: #1a6b3a; font-weight: 600; }

/* 我的排名固定栏 */
.my-rank-bar {
  background: #e6f4ec;
  padding: 16rpx 24rpx;
  border-bottom: 1rpx solid #c8e6c9;
}
.rank-num-sm {
  width: 40rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #1a6b3a;
  margin-right: 10rpx;
}
.my-name { font-size: 26rpx; font-weight: 600; color: #1a6b3a; margin-left: 10rpx; }
.my-score { font-size: 28rpx; font-weight: 700; color: #f5a623; margin-right: 12rpx; }
.my-rate { font-size: 22rpx; color: #888; }

/* 前三名 */
.board-list { flex: 1; }
.top3-row { padding: 40rpx 24rpx 20rpx; gap: 20rpx; align-items: flex-end; }
.top-item { text-align: center; }
.top-item.first { margin-bottom: 20rpx; }
.medal { font-size: 48rpx; }
.avatar-top { width: 96rpx; height: 96rpx; border-radius: 50%; display: block; margin: 8rpx auto; }
.top-item.first .avatar-top { width: 112rpx; height: 112rpx; border: 4rpx solid #f5a623; }
.top-name { font-size: 24rpx; color: #333; max-width: 120rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.top-score { font-size: 28rpx; font-weight: 700; color: #f5a623; }

/* 排行榜列表 */
.rank-row {
  padding: 20rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #f5f5f5;
}
.rank-row.is-me { background: #e6f4ec; }
.rank-num {
  width: 48rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #999;
  margin-right: 16rpx;
}
.rank-info { margin-left: 14rpx; }
.rank-name { font-size: 28rpx; color: #222; }
.rank-rate { font-size: 22rpx; color: #aaa; margin-top: 4rpx; }
.rank-score { font-size: 32rpx; font-weight: 700; color: #f5a623; }
.score-unit { font-size: 22rpx; color: #aaa; font-weight: normal; }
