.profile-page { min-height: 100vh; }

/* 头部 */
.profile-header {
  background: linear-gradient(135deg, #1a6b3a, #2d9e5f);
  padding: 40rpx 32rpx;
  display: flex;
  align-items: center;
  color: #fff;
}
.avatar-large { width: 100rpx; height: 100rpx; border-radius: 50%; border: 4rpx solid rgba(255,255,255,0.5); margin-right: 24rpx; }
.profile-name { font-size: 34rpx; font-weight: 700; margin-bottom: 8rpx; }
.champion-info { font-size: 24rpx; opacity: 0.85; }

/* 积分卡片 */
.score-card { margin-top: -20rpx; align-items: center; }
.score-main { padding: 20rpx 0; }
.score-big { font-size: 72rpx; font-weight: 700; color: #f5a623; line-height: 1; }
.score-label { font-size: 24rpx; color: #999; margin-top: 8rpx; }
.score-divider { width: 1rpx; background: #f0f0f0; height: 100rpx; }
.score-stats { padding: 16rpx 0 16rpx 24rpx; }
.score-stat-row { margin-bottom: 12rpx; }
.ss-label { font-size: 24rpx; color: #888; }
.ss-value { font-size: 26rpx; font-weight: 700; color: #333; }
.ss-value.green { color: #1a6b3a; }
.ss-value.orange { color: #f5a623; }

/* Tab */
.tab-bar { background: #fff; border-bottom: 1rpx solid #f0f0f0; }
.tab-item { flex: 1; text-align: center; padding: 24rpx 0; font-size: 28rpx; color: #666; border-bottom: 4rpx solid transparent; }
.tab-item.active { color: #1a6b3a; border-bottom-color: #1a6b3a; font-weight: 600; }

/* 积分构成 */
.card-title { font-size: 30rpx; font-weight: 700; color: #222; margin-bottom: 24rpx; }
.sb-row { padding: 16rpx 0; border-bottom: 1rpx solid #f5f5f5; align-items: center; }
.sb-name { font-size: 28rpx; color: #333; font-weight: 500; }
.sb-desc { font-size: 22rpx; color: #aaa; margin-top: 4rpx; }
.sb-score { font-size: 30rpx; font-weight: 700; color: #1a6b3a; }
.sb-score.orange { color: #f5a623; }
.sb-score.gold { color: #e6a817; }

/* 历史记录 */
.history-row { cursor: pointer; margin-bottom: 0; margin-top: 0; border-radius: 0; box-shadow: none; border-bottom: 1rpx solid #f5f5f5; border-radius: 0; }
.history-row:first-child { border-radius: 16rpx 16rpx 0 0; }
.history-row:last-child { border-radius: 0 0 16rpx 16rpx; border-bottom: none; }
.history-teams { font-size: 28rpx; color: #333; font-weight: 500; margin-bottom: 6rpx; }
.history-meta { font-size: 24rpx; color: #aaa; }
.history-score { font-size: 32rpx; font-weight: 700; color: #ccc; }
.history-score.positive { color: #f5a623; }
