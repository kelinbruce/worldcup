.group-page { min-height: 100vh; }

/* 创建群组 */
.create-card {}
.create-title { font-size: 28rpx; font-weight: 600; color: #222; margin-bottom: 16rpx; }
.create-row { gap: 12rpx; margin-bottom: 12rpx; }
.group-name-input {
  height: 72rpx;
  background: #f5f6fa;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}
.create-btn { padding: 0 30rpx; height: 72rpx; line-height: 72rpx; margin: 0; border-radius: 12rpx; }
.create-btn::after { border: none; }
.create-hint { font-size: 22rpx; color: #aaa; }

/* 群组卡片 */
.group-card { cursor: pointer; }
.group-name { font-size: 30rpx; font-weight: 600; color: #222; margin-bottom: 8rpx; }
.group-meta { font-size: 24rpx; color: #999; }
.group-arrow { color: #ccc; font-size: 32rpx; }
.empty-hint { font-size: 24rpx; color: #ccc; margin-top: 8rpx; }

/* 详情头部 */
.detail-header {
  background: #1a6b3a;
  padding: 20rpx 24rpx;
  color: #fff;
}
.back-btn { font-size: 28rpx; margin-right: 16rpx; cursor: pointer; }
.group-detail-name { font-size: 30rpx; font-weight: 700; }
.share-btn {
  background: rgba(255,255,255,0.2);
  color: #fff;
  border: 1rpx solid rgba(255,255,255,0.5);
  border-radius: 30rpx;
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  margin: 0;
}
.share-btn::after { border: none; }

/* 统计栏 */
.stats-bar { text-align: center; }
.stats-item {}
.stats-num { font-size: 36rpx; font-weight: 700; color: #333; }
.stats-num.green { color: #1a6b3a; }
.stats-num.orange { color: #f5a623; }
.stats-label { font-size: 22rpx; color: #999; margin-top: 4rpx; }

/* 最近比赛 */
.group-match-row { border-bottom: 1rpx solid #f5f5f5; padding: 16rpx 0; }
.group-match-info { margin-bottom: 10rpx; }
.gm-teams { font-size: 26rpx; color: #333; }
.gm-status { font-size: 20rpx; }
.gm-dist { height: 32rpx; border-radius: 4rpx; overflow: hidden; gap: 2rpx; margin-bottom: 8rpx; }
.gm-dist-item {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 40rpx;
  font-size: 20rpx;
  color: #fff;
}
.gm-dist-item.green { background: #1a6b3a; }
.gm-dist-item.gray { background: #aaa; }
.gm-dist-item.orange { background: #f5a623; }
.gm-result { font-size: 22rpx; color: #888; }
.correct-rate { color: #1a6b3a; font-weight: 700; }

/* 排行榜 */
.rank-row { padding: 16rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.rank-row.is-me { background: #e6f4ec; border-radius: 8rpx; padding: 16rpx 12rpx; margin: 0 -12rpx; }
.rank-badge {
  width: 48rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #bbb;
  margin-right: 12rpx;
}
.rank-badge.top { font-size: 32rpx; }
.rank-info { margin-left: 12rpx; }
.rank-name { font-size: 28rpx; color: #222; }
.rank-rate { font-size: 22rpx; color: #aaa; margin-top: 4rpx; }
.rank-score { font-size: 30rpx; font-weight: 700; color: #f5a623; }
.score-unit { font-size: 20rpx; color: #aaa; font-weight: normal; }
